{
	"name": "@internal/example-configuration",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "AB INNOVISION GmbH",
		"email": "info@abinnovision.com",
		"url": "https://abinnovision.com"
	},
	"scripts": {
		"build": "nest build",
		"format:check": "prettier --check 'src/**/*.ts' '*.{json{,5},md,y{,a}ml}'",
		"format:fix": "prettier --write 'src/**/*.ts' '*.{json{,5},md,y{,a}ml}'",
		"lint:check": "eslint 'src/**/*.ts'",
		"lint:fix": "eslint 'src/**/*.ts' --fix",
		"start": "nest start",
		"start:debug": "nest start --exec \"node --inspect-brk\" --watch",
		"start:dev": "nest start --watch"
	},
	"lint-staged": {
		"src/**/*.ts": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json{,5},md,y{,a}ml}": "prettier --write"
	},
	"prettier": "@abinnovision/prettier-config",
	"dependencies": {
		"@abinnovision/nestjs-configx": "workspace:^",
		"@nestjs/common": "^11.1.17",
		"@nestjs/core": "^11.1.17",
		"@nestjs/platform-express": "^11.1.17",
		"@nestjs/swagger": "^11.2.6",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@abinnovision/eslint-config-base": "^3.2.0",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.17",
		"@swc/cli": "^0.7.10",
		"@swc/core": "^1.15.18",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"eslint": "^9.39.4",
		"prettier": "^3.8.1",
		"source-map-support": "^0.5.21",
		"typescript": "^5.9.3",
		"unplugin-swc": "^1.5.9"
	}
}
