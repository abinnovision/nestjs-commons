{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@internal/nestjs-commons",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "turbo run build",
		"build:packages": "turbo run build --filter='./packages/*'",
		"build:packages:watch": "turbo watch build --filter='./packages/*'",
		"check": "yarn format:check && yarn sort:check && turbo run check",
		"fix": "yarn format:fix && yarn sort:fix && turbo run fix",
		"format:check": "prettier --ignore-path .gitignore --check '{.github/**/*,*}.{json{,5},md,y{,a}ml,{c,m,}{j,t}s}'",
		"format:fix": "prettier --ignore-path .gitignore --write '{.github/**/*,*}.{json{,5},md,y{,a}ml,{c,m,}{j,t}s}'",
		"postinstall": "husky",
		"lint:check": "eslint '*.{m,c,}{j,t}s'",
		"lint:fix": "eslint '*.{m,c,}{j,t}s' --fix",
		"sort:check": "sort-package-json '{apps,packages}/**!(node_modules)/package.json' 'package.json' --check",
		"sort:fix": "sort-package-json '{apps,packages}/**!(node_modules)/package.json' 'package.json'",
		"test": "vitest run --coverage",
		"test-unit": "vitest run --project '*#unit' --coverage"
	},
	"commitlint": {
		"extends": [
			"@abinnovision/commitlint-config"
		]
	},
	"lint-staged": {
		"**/package.json": "sort-package-json",
		"{.github/**/*,*}.{json{,5},md,y{,a}ml}": "prettier --write"
	},
	"prettier": "@abinnovision/prettier-config",
	"resolutions": {
		"rolldown-plugin-dts@npm:^0.25.2": "patch:rolldown-plugin-dts@npm%3A0.25.2#~/.yarn/patches/rolldown-plugin-dts-npm-0.25.2-106fad70f1.patch"
	},
	"devDependencies": {
		"@abinnovision/commitlint-config": "^2.3.0",
		"@abinnovision/eslint-config-base": "^3.4.1",
		"@abinnovision/prettier-config": "^2.2.0",
		"@commitlint/cli": "^21.2.0",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^10.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.9.4",
		"sort-package-json": "^4.0.0",
		"turbo": "^2.10.0",
		"vitest": "^4.1.6"
	},
	"packageManager": "yarn@4.16.0"
}
